# --- PERFORMANCE & MOCK SETTINGS ---
# Set MOCK_SIEM to 'true' to ensure the app ALWAYS works (using sample data).
# Set to 'false' ONLY when you want to connect to your live Elasticsearch/Wazuh server.
MOCK_SIEM=false

# --- LLM SETTINGS ---
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# --- SIEM (ELASTICSEARCH/WAZUH) SETTINGS ---
# These are used only when MOCK_SIEM=false
ELASTICSEARCH_URL=https://localhost:9200
ELASTICSEARCH_USER=admin
ELASTICSEARCH_PASSWORD=your_password_here
ELASTICSEARCH_API_KEY=
